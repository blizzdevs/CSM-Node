<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

<%- include('../partials/nav') %>

<main class="content-wrapper">
    <div class="auth-wrapper">
        <div class="auth-box" style="max-width:520px;">

            <h1 class="auth-title">Create <span>Account</span></h1>

            <!-- Errores de validación (lista) -->
            <% if (errors && errors.length > 0) { %>
                <div class="alert alert-error">
                    <ul>
                        <% errors.forEach(function(e) { %>
                            <li><%= e.msg %></li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>

            <form action="/register" method="POST" class="card" style="padding:30px;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="form-group">
                    <label class="form-label" for="username">
                        Username
                        <span style="float:right;color:var(--text-sec);font-weight:400;text-transform:none;letter-spacing:0;">4–10 characters, letters and numbers only</span>
                    </label>
                    <input
                        type="text"
                        id="username"
                        name="username"
                        class="form-input"
                        value="<%= old.username || '' %>"
                        minlength="4"
                        maxlength="10"
                        autocomplete="username"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">
                        Password
                        <span style="float:right;color:var(--text-sec);font-weight:400;text-transform:none;letter-spacing:0;">4–12 characters</span>
                    </label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        class="form-input"
                        minlength="4"
                        maxlength="12"
                        autocomplete="new-password"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="cpassword">Confirm Password</label>
                    <input
                        type="password"
                        id="cpassword"
                        name="cpassword"
                        class="form-input"
                        minlength="4"
                        maxlength="12"
                        autocomplete="new-password"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="email">Email Address</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="form-input"
                        value="<%= old.email || '' %>"
                        autocomplete="email"
                        required
                    >
                </div>

                <p style="font-size:11px;color:var(--text-sec);margin-bottom:20px;line-height:1.6;">
                    By registering you agree to our <a href="/tos" style="color:var(--accent);">Terms of Service</a>.
                </p>

                <button type="submit" class="btn btn-primary btn-block">
                    Create Account
                </button>
            </form>

            <div class="auth-footer-link">
                Already have an account? <a href="/login">Login here</a>
            </div>

        </div>
    </div>
</main>

<%- include('../partials/footer') %>
</body>
</html>
