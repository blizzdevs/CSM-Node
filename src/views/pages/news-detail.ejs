<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .news-content { font-size:14px; line-height:1.9; color:var(--text); }
        .news-content p { margin-bottom:1em; }
        .news-content h1,.news-content h2,.news-content h3 { font-family:var(--font-h);text-transform:uppercase;letter-spacing:.08em;color:var(--gold);margin:1.4em 0 .6em; }
        .news-content img { max-width:100%;margin:12px 0; }
        .news-content a { color:var(--accent);text-decoration:underline; }
        .news-content ul,.news-content ol { margin:1em 0 1em 1.5em; }
        .news-content li { margin-bottom:.4em; }
        .news-content table { border-collapse:collapse;width:100%;margin:1em 0; }
        .news-content td,.news-content th { border:1px solid var(--border);padding:8px 12px;font-size:13px; }
        .news-content th { background:var(--accent);font-family:var(--font-h);text-transform:uppercase;font-size:11px;letter-spacing:.06em; }
    </style>
</head>
<body>
<%- include('../partials/nav') %>
<main class="content-wrapper">
<div class="container" style="padding-top:40px;padding-bottom:60px;max-width:860px;">

    <a href="/news" style="font-family:var(--font-h);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--text-sec);display:inline-block;margin-bottom:24px;">← Back to News</a>

    <div class="card">
        <div style="padding-bottom:18px;border-bottom:1px solid var(--border);margin-bottom:24px;">
            <h1 style="font-family:var(--font-h);font-size:26px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:var(--text);margin-bottom:10px;">
                <%= article.news_title %>
            </h1>
            <div style="font-size:11px;color:var(--text-sec);">
                By <span style="color:var(--gold);font-family:var(--font-mono)"><%= article.news_author %></span>
                &nbsp;·&nbsp;
                <%= new Date(article.news_date * 1000).toLocaleDateString('en-US', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %>
            </div>
        </div>
        <div class="news-content">
            <%- article.news_content %>
        </div>
    </div>
</div>
</main>
<%- include('../partials/footer') %>
</body>
</html>
