<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .forgot-page {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 70vh;
            padding: 40px 20px;
        }
        .forgot-box {
            width: 100%;
            max-width: 480px;
        }
    </style>
</head>
<body>
<%- include('../partials/nav') %>

<main class="content-wrapper forgot-page">
    <div class="card forgot-box">
        <h2 style="font-family: var(--font-h); text-align: center; font-size: 24px; margin-bottom: 20px;">Recover Password</h2>
        
        <p style="text-align: center; color: var(--text-sec); font-size: 14px; margin-bottom: 30px;">
            Enter your registered email address and we will send you a recovery link to reset your password.
        </p>

        <% if (flashError && flashError.length > 0) { %>
            <div class="flash-error" style="margin-bottom: 20px;"><%= flashError[0] %></div>
        <% } %>
        <% if (flashSuccess && flashSuccess.length > 0) { %>
            <div class="flash-success" style="margin-bottom: 20px;"><%= flashSuccess[0] %></div>
        <% } %>

        <form action="/forgot" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" class="form-control" required placeholder="your.email@example.com">
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; margin-top: 10px;">Recover Account</button>
        </form>

        <div style="text-align: center; margin-top: 25px; font-size: 13px;">
            <a href="/login" class="text-sec" style="color:var(--text-sec);text-decoration:none;">Remembered your password? <span style="color:var(--gold);">Sign in</span></a>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
</body>
</html>
