# ═══════════════════════════════════════════
# NodeEngine CMS — Variables de Entorno
# Copiá este archivo a .env y completá los valores
# NUNCA subas .env al repositorio
# ═══════════════════════════════════════════

# ── Servidor ────────────────────────────────
PORT=3000
NODE_ENV=development
# En producción: NODE_ENV=production

# ── Base de datos principal (MuOnline) ──────
# Tabla de juego: MEMB_INFO, Character, Guild, etc.
DATABASE_URL="sqlserver://HOST:1433;database=MuOnline;user=sa;password=TU_PASSWORD;encrypt=true;trustServerCertificate=true"

# ── Base de datos del CMS (Me_MuOnline) ─────
# Tablas propias: WEBENGINE_NEWS, WEBENGINE_BANS, etc.
DATABASE_CMS_URL="sqlserver://HOST:1433;database=Me_MuOnline;user=sa;password=TU_PASSWORD;encrypt=true;trustServerCertificate=true"

# Variables individuales para connect-mssql-v2 (sesiones)
DB_HOST=localhost
DB_PORT=1433
DB_NAME=Me_MuOnline
DB_USER=sa
DB_PASS=TU_PASSWORD

# ── Sesión ───────────────────────────────────
# Cambiá este valor por una cadena aleatoria larga en producción
SESSION_SECRET=cambia_esto_por_algo_muy_largo_y_aleatorio_en_produccion

# ── Encriptación de contraseñas ─────────────
# Opciones: phpmd5 | sha256 | wzmd5
# phpmd5  = md5(password)  — más común en S6
# sha256  = sha256(password + username + salt)
# wzmd5   = fn_md5 SQL Server (requiere stored procedure en DB)
ENCRYPTION_METHOD=phpmd5

# Salt para sha256 (solo se usa si ENCRYPTION_METHOD=sha256)
SHA256_SALT=cambia_esto_en_produccion

# ── Google reCAPTCHA v2 ──────────────────────
RECAPTCHA_SITE_KEY=TU_SITE_KEY
RECAPTCHA_SECRET_KEY=TU_SECRET_KEY

# ── Email (SMTP / Nodemailer) ────────────────
# Equivalente a PHPMailer en WebEngine
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=correo@example.com
SMTP_PASS=TU_PASSWORD_SMTP
SMTP_FROM_NAME=NodeEngine CMS
SMTP_FROM_EMAIL=noreply@example.com

# ── Admin ────────────────────────────────────
# Prefijo del panel de administración (seguridad por obscuridad)
ADMIN_PREFIX=admincp
# Timeout de sesión admin en segundos (1800 = 30 minutos)
ADMIN_SESSION_TIMEOUT=1800
